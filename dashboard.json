      {
        "id": 12,
        "title": "Token Breakdown (Input vs Output)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 48 },
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "dfgs4kylnfawwb" },
        "targets": [
          {
            "refId": "A",
            "type": "json",
            "source": "url",
            "url": "http://10.255.245.162:3000/api/grafana/usage",
            "url_options": { "method": "GET" },
            "columns": [
              { "selector": "time", "text": "Time", "type": "timestamp" },
              { "selector": "claw", "text": "Claw", "type": "string" },
              { "selector": "input_tokens", "text": "Input Tokens", "type": "number" },
              { "selector": "output_tokens", "text": "Output Tokens", "type": "number" }
            ],
            "format": "timeseries"
          }
        ],
        "fieldConfig": {
          "defaults": {
